body {
    font-family: 'Segoe UI', sans-serif;
}

.hero {
    background: linear-gradient(to right, #0d6efd, #6610f2);
    color: white;
    padding: 100px 0;
    text-align: center;
}

.section-title {
    font-weight: bold;
    margin-bottom: 40px;
}

.card:hover {
    transform: scale(1.05);
    transition: 0.3s;
}

footer {
    background: #111;
    color: #ccc;
    padding: 20px;
    text-align: center;
}
